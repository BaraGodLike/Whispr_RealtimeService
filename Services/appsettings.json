{
  "Realtime": {
    "NodeId": "realtime-1",
    "RedisLeaseTtl": "00:01:00",
    "LeaseRefreshInterval": "00:00:25",
    "HeartbeatCheckInterval": "00:00:10",
    "AuthTimeout": "00:00:15",
    "MaxPayloadBytes": 262144,
    "MaxResumeBatchSize": 500,
    "RelayGetMessageRetry": {
      "MaxAttempts": 3,
      "InitialBackoff": "00:00:00.200"
    }
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "MailboxGrpc": {
    "Address": "https://localhost:7001"
  },
  "RelayGrpc": {
    "Address": "https://localhost:7002"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "message.enqueued",
    "GroupIdPrefix": "realtime",
    "AutoOffsetReset": "Latest",
    "RetryDelay": "00:00:01"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Application": "Information",
      "Realtime.Services": "Information",
      "Infrastructure.Redis": "Warning",
      "Infrastructure.Grpc": "Warning",
      "Infrastructure.Messaging": "Warning"
    }
  }
}
